generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Problem {
  id              String     @id
  platform        String     @default("LEETCODE")
  pid             String
  title           String
  slug            String?
  url             String?
  difficulty      String
  difficultyLevel Int        @default(1)
  tags            String
  progress        Progress[]

  @@unique([platform, pid])
}

model Progress {
  id           String       @id
  userId       String
  problemId    String
  status       String       @default("Todo")
  notes        String?
  masteryLevel Int          @default(0)
  interval     Int          @default(0)
  easiness     Float        @default(2.5)
  reviewCount  Int          @default(0)
  lastReview   DateTime?
  nextReview   DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  problem      Problem      @relation(fields: [problemId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  submissions  Submission[]

  @@unique([userId, problemId])
}

model Submission {
  id         String   @id
  progressId String
  language   String
  code       String
  isMain     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  progress   Progress @relation(fields: [progressId], references: [id])
}

model User {
  id               String     @id
  username         String     @unique
  avatar           String?
  preferredLang    String     @default("typescript")
  uiLanguage       String     @default("en")
  themeColor       String     @default("emerald")
  dailyReviewLimit Int        @default(50)
  createdAt        DateTime   @default(now())
  progress         Progress[]
}
